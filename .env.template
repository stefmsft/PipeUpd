# Source des rapport Sales Force
DIRECTORY_PIPE_RAW=

# Fichier de suivi en entrée
INPUT_SUIVI_RAW=

# Fichier de suivi en sortie
OUTPUT_SUIVI_RAW=


# [DEPRECATED] Number of header rows in Salesforce report
# AUTO-DETECTION: The system now automatically detects header rows
# This setting is kept for backward compatibility only
# Leave commented out to use automatic detection (recommended)
#SKIP_ROW=12

# Granularité sur la date
GRANULARITE='Date'
GRANULARITE_COL=0

# Max delta between both normalization
NORMAXDELTA=10000000

# Fenetre de Rotation - On extrait en presentation sur Analysis les n dernieres valeures de Pipe Log
# Pas plus de 31
ROLLINGWINDOWS=31

# Colonne impacté par la rotation des valeur sur le tab Analysis
ROLLINGFIELD='Date'

# For testing: Override current week number (1-53). If not set, uses actual current week
#CURWEEK=35

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable Unicode icons in output (⚠️ instead of [!])
# Set to 'true' if using PowerShell 7.5+ or on Linux/Mac
# Leave commented or set to 'false' for older Windows PowerShell (default: false on Windows)
#ENABLE_UNICODE=true

# Enable BackUp of Pipe File in case of futur corruption - Thanks to OneDrive Sync
#BCKUP_PIPE_FILE=True
#BCKUP_DIRECTORY="Some Dir"
# if a file is already there with the same granularity, no new backup is done - Could be "hours" or "days". With the late we only backup one time per day even if we launch the script multiple time
#BCKUP_GRANULARITY="days"

# Excluded owners from pipeline processing (comma-separated list)
# These owners will be removed from the main pipeline data
# Example: EXCLUDED_PIPE_OWNERS="John DOE,Jane SMITH"
EXCLUDED_PIPE_OWNERS=

# Excluded owners from Owner Opportunity Tracking report (comma-separated list)
# Example: EXCLUDED_OPTY_OWNERS=John DOE,Jane SMITH,Old Owner
EXCLUDED_OPTY_OWNERS=

# Owner Opportunity Tracking: Number of weeks to track in the detail table (Tab 2)
# Default: 13 weeks (current week + 12 weeks back)
WEEKS_TO_TRACK_DETAILS=13

# Owner Opportunity Tracking: Starting line for Tab 2 (Weekly Detail)
# Tab 1 (Owner Summary) spreads from the top, Tab 2 starts at this fixed line
# An error will be shown if Tab 1 content exceeds this line
LINE_LAST_5W_OPTY=28

# Hidden tabs: Comma-separated list of Excel sheet names to hide
# Hidden tabs can be unhidden through Excel UI (Right-click on any tab > Unhide)
# Default hides internal/technical tabs while keeping main pipeline visible
# To show all tabs, set to empty or comment out this line
HIDDEN_TABS=Owner Opty Tracking,Week History,Pipeline Close Lost

# FixPipe: Pivot table filter cleanup
# Use numbered groups (1, 2, 3 …) — one group per field you want to control.
#
# PIVOT_FILTER_N_TABS     Comma-separated list of Excel sheet tab names to scan.
#                         Every pivot table on those tabs is checked; only the ones
#                         that have the matching field as a page filter are modified.
#                         Default (if omitted): "By Sales"
#
# PIVOT_FILTER_N_FIELD    Partial field name (case-insensitive, first-line match).
#                         e.g. "Quarter Invoice" matches "Quarter Invoice_x000a_Facturation"
#
# PIVOT_FILTER_N_ALLOWED  Comma-separated whitelist of values to KEEP in the dropdown.
#                         Items present in the cache but NOT in this list are removed,
#                         even when they appear in the source data.
#                         Leave empty or omit to keep all values found in the data.
#
# PIVOT_FILTER_N_SELECTED Comma-separated values to mark as SELECTED (checked) in the
#                         active filter.  All other values are unchecked (hidden).
#                         Leave empty or omit to leave the current selection unchanged.
#
# Example — restrict Quarter Invoice dropdown and pre-select current fiscal year:
#PIVOT_FILTER_1_TABS=By Sales
#PIVOT_FILTER_1_FIELD=Quarter Invoice
#PIVOT_FILTER_1_ALLOWED=Q1FY25,Q2FY25,Q3FY25,Q4FY25,Q1FY26,Q2FY26,Q3FY26,Q4FY26
#PIVOT_FILTER_1_SELECTED=Q1FY26,Q2FY26,Q3FY26,Q4FY26
#
# Example — restrict Product Family dropdown:
#PIVOT_FILTER_2_TABS=By Sales
#PIVOT_FILTER_2_FIELD=Product Family
#PIVOT_FILTER_2_ALLOWED=NX,NB,NR,PF,PT
#PIVOT_FILTER_2_SELECTED=